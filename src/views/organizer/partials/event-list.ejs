<%
  const sections = [
    {
      key: "published",
      title: "Published",
      description: "Live events that attendees can RSVP to.",
      events: groupedEvents.published,
      emptyMessage: "No published events yet.",
      sectionClass: "border-green-200 bg-green-50/50",
    },
    {
      key: "draft",
      title: "Draft",
      description: "Work-in-progress events not visible to members.",
      events: groupedEvents.draft,
      emptyMessage: "No draft events.",
      sectionClass: "border-slate-200 bg-slate-50/60",
    },
    {
      key: "cancelledOrPast",
      title: "Cancelled Or Past",
      description: "Archived events with no active attendance updates.",
      events: groupedEvents.cancelledOrPast,
      emptyMessage: "No cancelled or past events.",
      sectionClass: "border-red-200 bg-red-50/40",
    },
  ];

  const totalEvents = sections.reduce((sum, section) => sum + section.events.length, 0);
%>

<% if (totalEvents === 0) { %>
  <p class="text-gray-500">You have not created any events yet.</p>
<% } else { %>
  <div class="space-y-6">
    <% sections.forEach((section) => { %>
      <section class="border rounded-xl p-4 <%= section.sectionClass %>">
        <div class="flex items-baseline justify-between gap-4 mb-3">
          <div>
            <h2 class="text-lg font-semibold"><%= section.title %></h2>
            <p class="text-sm text-gray-500"><%= section.description %></p>
          </div>
          <span class="text-xs font-semibold uppercase tracking-wide text-gray-600">
            <%= section.events.length %> event<%= section.events.length === 1 ? "" : "s" %>
          </span>
        </div>

        <% if (section.events.length === 0) { %>
          <p class="text-sm text-gray-500"><%= section.emptyMessage %></p>
        <% } else { %>
          <ul class="space-y-3">
            <% section.events.forEach((event) => { %>
              <% const start = new Date(event.startDatetime); %>
              <% const end = new Date(event.endDatetime); %>
              <% const isPast = end < new Date(); %>
              <li class="border rounded-lg p-4 bg-white" id="organizer-event-<%= event.id %>">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <a href="/events/<%= event.id %>" class="font-semibold text-lg text-blue-700 hover:underline">
                      <%= event.title %>
                    </a>
                    <p class="text-sm text-gray-500">
                      <%= event.location %> &middot; <%= event.category %>
                    </p>
                    <p class="text-sm text-gray-500 mt-1">
                      <%= start.toLocaleDateString() %>
                      <%= start.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
                      &ndash;
                      <%= end.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
                    </p>
                    <p class="text-sm text-gray-500 mt-1">
                      Attendance: <%= event.attendeeCount %>
                      <% if (event.capacity !== null) { %>
                        / <%= event.capacity %>
                      <% } else { %>
                        / no limit
                      <% } %>
                    </p>
                    <% if (actingUserRole === "admin") { %>
                      <p class="text-xs text-gray-400 mt-1">Organizer: <%= event.organizerId %></p>
                    <% } %>
                  </div>

                  <div class="flex flex-col items-end gap-2">
                    <span class="text-xs font-medium px-2 py-1 rounded-full <%= event.status === "published" ? "bg-green-100 text-green-800" : event.status === "draft" ? "bg-gray-100 text-gray-800" : "bg-red-100 text-red-800" %>">
                      <%= isPast && event.status !== "cancelled" ? "past" : event.status %>
                    </span>

                    <% if (event.canPublish) { %>
                      <form
                        hx-post="/events/<%= event.id %>/publish"
                        hx-swap="none"
                        hx-on::after-request="htmx.trigger(document.body, 'organizer-dashboard-refresh')"
                      >
                        <button type="submit" class="text-sm px-3 py-1 rounded bg-green-600 text-white hover:bg-green-700">
                          Publish
                        </button>
                      </form>
                    <% } %>

                    <% if (event.canCancel) { %>
                      <form
                        hx-post="/events/<%= event.id %>/cancel"
                        hx-swap="none"
                        hx-on::after-request="htmx.trigger(document.body, 'organizer-dashboard-refresh')"
                      >
                        <button type="submit" class="text-sm px-3 py-1 rounded bg-red-600 text-white hover:bg-red-700">
                          Cancel
                        </button>
                      </form>
                    <% } %>
                  </div>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    <% }) %>
  </div>
<% } %>
