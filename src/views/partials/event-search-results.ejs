<% if (events && events.length > 0) { %>
  <div class="grid gap-4">
    <% events.forEach(event => { %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <a href="/events/<%= event.id %>" class="text-xl font-bold text-slate-900 hover:text-blue-700 hover:underline">
              <%= event.title %>
            </a>

            <div class="mt-2 flex flex-wrap gap-2 text-sm text-slate-600">
              <span class="rounded-full bg-slate-100 px-3 py-1">
                <%= event.category %>
              </span>
              <span class="rounded-full bg-slate-100 px-3 py-1">
                <%= event.location %>
              </span>
            </div>
          </div>

          <span class="rounded-full bg-blue-50 px-3 py-1 text-sm font-semibold text-blue-700">
            <%= new Date(event.startDatetime).toLocaleDateString() %>
          </span>
        </div>

        <p class="mt-4 text-sm leading-6 text-slate-700">
          <%= event.description %>
        </p>

        <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-slate-100 pt-4 text-sm">
          <span class="text-slate-500">
            <strong>Start:</strong> <%= new Date(event.startDatetime).toLocaleString() %>
          </span>

          <div class="flex items-center gap-3">
            <a href="/events/<%= event.id %>" class="font-semibold text-blue-700 hover:underline">
              View details
            </a>
            <a href="/events/<%= event.id %>/edit" class="font-semibold text-slate-600 hover:text-slate-900 hover:underline">
              Edit
            </a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
<% } else { %>
  <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center shadow-sm">
    <p class="text-lg font-semibold text-slate-800">No matching events found.</p>
    <p class="mt-2 text-sm text-slate-500">Try clearing your search or changing your filters.</p>
  </div>
<% } %>