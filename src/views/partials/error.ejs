<section class="mb-4 p-4 rounded-xl border border-red-200 bg-red-50 text-red-800" aria-live="polite">
  <h3 class="text-base font-semibold mb-1">Error</h3>
  <p class="mb-0 text-sm"><%= message %></p>
  <% if (typeof name !== 'undefined') { %>
    <span data-error-name="<%= name %>" class="hidden"><%= name %></span>
  <% } %>
</section>