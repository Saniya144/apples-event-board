<% if (typeof waitlistPosition !== 'undefined' && waitlistPosition !== null) { %>
  <div class="flex items-stretch gap-0 rounded-xl overflow-hidden border border-amber-300 bg-amber-50 mb-4 shadow-sm">
    <div class="w-1.5 bg-amber-400 shrink-0"></div>
    <div class="flex items-center gap-4 px-5 py-4 w-full">
      <div class="text-3xl leading-none select-none">⏳</div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-amber-900 uppercase tracking-wide">Waitlist Position</p>
        <p class="text-4xl font-extrabold text-amber-700 leading-tight">#<%= waitlistPosition %></p>
        <p class="text-xs text-amber-700 mt-1">You'll be automatically promoted if a spot opens up.</p>
      </div>
    </div>
  </div>
<% } %>

<div id="rsvp-section"
  x-data="{ status: '<%= rsvpStatus ?? 'none' %>', loading: false }"
>
  <form
    hx-post="/events/<%= eventId %>/rsvp"
    hx-target="#rsvp-actions-section"
    hx-swap="innerHTML"
    @htmx:before-request="loading = true"
  >
    <button
      type="submit"
      :disabled="loading"
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      :class="{
        'bg-green-600 hover:bg-green-700': status === 'going',
        'bg-yellow-500 hover:bg-yellow-600': status === 'waitlisted',
        'bg-blue-600 hover:bg-blue-700': status !== 'going' && status !== 'waitlisted',
        'opacity-50 cursor-wait': loading
      }"
      class="rounded-lg text-white px-4 py-2 transition-colors duration-200"
    >
      <span x-show="loading">Loading...</span>
      <span x-show="!loading && status === 'going'">✓ Going — Click to Cancel</span>
      <span x-show="!loading && status === 'waitlisted'">⏳ Waitlisted — Click to Leave Waitlist</span>
      <span x-show="!loading && status !== 'going' && status !== 'waitlisted'">RSVP to this Event</span>
    </button>
  </form>

  <% if (rsvpError) { %>
    <p class="text-sm text-red-600 mt-2"><%= rsvpError %></p>
  <% } %>
</div>

<% if (typeof attendeeCount !== 'undefined' && attendeeCount !== null) { %>
<div id="attendance-count" hx-swap-oob="true" class="rounded-lg border p-4 md:col-span-2">
  <p class="font-semibold text-slate-800">Attendance</p>
  <p class="text-slate-600">
    <%= attendeeCount %>
    <% if (typeof capacity !== 'undefined' && capacity !== null) { %>
      / <%= capacity %>
    <% } else { %>
      / no limit
    <% } %>
  </p>
</div>
<% } %>
