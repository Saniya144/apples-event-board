<%
  const start = new Date(event.startDatetime);
  const end = new Date(event.endDatetime);
  const statusLabel = event.status;
  const safeDomId = event.id.replace(/[^A-Za-z0-9_-]/g, "-");
  const oobDeleteEmptyState = typeof oobDeleteEmptyStateId === "string" && oobDeleteEmptyStateId
    ? `<div id="${oobDeleteEmptyStateId}" hx-swap-oob="delete"></div>`
    : "";
%>
<%- oobDeleteEmptyState %>
<% if (typeof oobTarget === "string" && oobTarget) { %>
  <div id="organizer-event-<%= safeDomId %>" hx-swap-oob="delete"></div>
  <li
    class="rounded-xl bg-white/90 shadow-sm ring-1 ring-black/5 p-4 transition hover:-translate-y-0.5 hover:shadow-md <%= event.status === "published" ? "border-l-4 border-emerald-400" : event.status === "draft" ? "border-l-4 border-amber-400" : "border-l-4 border-slate-400" %>"
    id="organizer-event-<%= safeDomId %>"
    hx-swap-oob="beforeend:#<%= oobTarget %>"
  >
    <div class="flex items-start justify-between gap-4">
      <div>
        <a href="/events/<%= event.id %>" class="font-semibold text-lg text-slate-900 hover:text-blue-700 hover:underline">
          <%= event.title %>
        </a>
        <p class="text-sm text-slate-600">
          <%= event.location %> &middot; <%= event.category %>
        </p>
        <p class="text-sm text-slate-600 mt-1">
          <%= start.toLocaleDateString() %>
          <%= start.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
          &ndash;
          <%= end.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
        </p>
        <p class="text-sm text-slate-600 mt-1">
          Attendance: <%= event.attendeeCount %>
          <% if (event.capacity !== null) { %>
            / <%= event.capacity %>
          <% } else { %>
            / no limit
          <% } %>
        </p>
        <% if (actingUserRole === "admin") { %>
          <p class="text-xs text-slate-400 mt-1">Organizer: <%= event.organizerId %></p>
        <% } %>
      </div>

      <div class="flex flex-col items-end gap-2">
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wide <%= event.status === "published" ? "bg-emerald-100 text-emerald-800" : event.status === "draft" ? "bg-amber-100 text-amber-800" : "bg-slate-200 text-slate-700" %>">
          <%= statusLabel %>
        </span>
      </div>
    </div>
  </li>
<% } else { %>
  <li class="rounded-xl bg-white/90 shadow-sm ring-1 ring-black/5 p-4 transition hover:-translate-y-0.5 hover:shadow-md <%= event.status === "published" ? "border-l-4 border-emerald-400" : event.status === "draft" ? "border-l-4 border-amber-400" : "border-l-4 border-slate-400" %>" id="organizer-event-<%= safeDomId %>">
    <div class="flex items-start justify-between gap-4">
      <div>
        <a href="/events/<%= event.id %>" class="font-semibold text-lg text-slate-900 hover:text-blue-700 hover:underline">
          <%= event.title %>
        </a>
        <p class="text-sm text-slate-600">
          <%= event.location %> &middot; <%= event.category %>
        </p>
        <p class="text-sm text-slate-600 mt-1">
          <%= start.toLocaleDateString() %>
          <%= start.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
          &ndash;
          <%= end.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %>
        </p>
        <p class="text-sm text-slate-600 mt-1">
          Attendance: <%= event.attendeeCount %>
          <% if (event.capacity !== null) { %>
            / <%= event.capacity %>
          <% } else { %>
            / no limit
          <% } %>
        </p>
        <% if (actingUserRole === "admin") { %>
          <p class="text-xs text-slate-400 mt-1">Organizer: <%= event.organizerId %></p>
        <% } %>
      </div>

      <div class="flex flex-col items-end gap-2">
        <span class="text-xs font-semibold px-2.5 py-1 rounded-full uppercase tracking-wide <%= event.status === "published" ? "bg-emerald-100 text-emerald-800" : event.status === "draft" ? "bg-amber-100 text-amber-800" : "bg-slate-200 text-slate-700" %>">
          <%= statusLabel %>
        </span>

        <% if (event.canPublish) { %>
          <form
            hx-post="/events/<%= event.id %>/publish"
            hx-target="#event-list"
            hx-swap="innerHTML"
          >
            <button type="submit" class="text-sm px-3 py-1.5 rounded-full bg-emerald-600 text-white hover:bg-emerald-700 transition">
              Publish
            </button>
          </form>
        <% } %>

        <% if (event.canCancel) { %>
          <form
            hx-post="/events/<%= event.id %>/cancel"
            hx-target="#event-list"
            hx-swap="innerHTML"
          >
            <button type="submit" class="text-sm px-3 py-1.5 rounded-full bg-rose-600 text-white hover:bg-rose-700 transition">
              Cancel
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </li>
<% } %>