<!-- src/views/partials/rsvp-button.ejs -->
<div id="rsvp-section">
  <% if (rsvpStatus === "going") { %>
    <form
      hx-post="/events/<%= eventId %>/rsvp"
      hx-target="#rsvp-section"
      hx-swap="outerHTML"
    >
      <button
        type="submit"
        class="rounded-lg bg-green-600 text-white px-4 py-2 hover:bg-green-700 transition-colors"
      >
        ✓ Going — Click to Cancel
      </button>
    </form>

  <% } else if (rsvpStatus === "waitlisted") { %>
    <form
      hx-post="/events/<%= eventId %>/rsvp"
      hx-target="#rsvp-section"
      hx-swap="outerHTML"
    >
      <button
        type="submit"
        class="rounded-lg bg-yellow-500 text-white px-4 py-2 hover:bg-yellow-600 transition-colors"
      >
        ⏳ Waitlisted — Click to Leave Waitlist
      </button>
    </form>

  <% } else { %>
    <form
      hx-post="/events/<%= eventId %>/rsvp"
      hx-target="#rsvp-section"
      hx-swap="outerHTML"
    >
      <button
        type="submit"
        class="rounded-lg bg-blue-600 text-white px-4 py-2 hover:bg-blue-700 transition-colors"
      >
        RSVP to this Event
      </button>
    </form>
  <% } %>

  <% if (rsvpError) { %>
    <p class="text-sm text-red-600 mt-2"><%= rsvpError %></p>
  <% } %>
</div>

<% if (typeof attendeeCount !== 'undefined' && attendeeCount !== null) { %>
<div id="attendance-count" hx-swap-oob="true" class="rounded-lg border p-4 md:col-span-2">
  <p class="text-sm font-medium text-gray-500 mb-1">Attendance</p>
  <p class="text-lg font-semibold">
    <%= attendeeCount %>
    <% if (typeof capacity !== 'undefined' && capacity !== null) { %>
      / <%= capacity %>
    <% } %>
  </p>
</div>
<% } %>