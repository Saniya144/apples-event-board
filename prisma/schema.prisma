generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id            String  @id @default(cuid())
  title         String
  description   String
  location      String
  category      String
  status        String  @default("draft")
  capacity      Int?
  startDatetime String
  endDatetime   String
  organizerId   String
  createdAt     String
  updatedAt     String
  rsvps         Rsvp[]
}

model Rsvp {
  id        String @id @default(cuid())
  eventId   String
  userId    String
  status    String
  createdAt String

  event     Event  @relation(fields: [eventId], references: [id])

  @@unique([eventId, userId])
}