<%
  const statusConfig = {
    draft:     { bg: 'bg-slate-100',  text: 'text-slate-700',  label: 'Draft'     },
    published: { bg: 'bg-green-100',  text: 'text-green-800',  label: 'Published' },
    cancelled: { bg: 'bg-red-100',    text: 'text-red-800',    label: 'Cancelled' },
    past:      { bg: 'bg-yellow-100', text: 'text-yellow-800', label: 'Past'      },
  };
  const sc = statusConfig[event.status] || statusConfig.draft;

  function fmtDate(iso) {
    return new Date(iso).toLocaleString('en-US', {
      weekday: 'short', month: 'short', day: 'numeric',
      year: 'numeric', hour: 'numeric', minute: '2-digit'
    });
  }

  const fillPct = event.capacity
    ? Math.min(100, Math.round((attendeeCount / event.capacity) * 100))
    : null;
  const fillColor = fillPct >= 90 ? 'bg-red-500' : fillPct >= 70 ? 'bg-yellow-500' : 'bg-green-500';
%>

<div
  class="max-w-4xl mx-auto p-6 space-y-6"
  x-data="{
    relativeTime(iso) {
      const d = new Date(iso);
      const now = new Date();
      const diffH = Math.round((d - now) / 3600000);
      const diffD = Math.round((d - now) / 86400000);
      if (Math.abs(diffH) < 1) return 'now';
      if (Math.abs(diffH) < 24) return diffH > 0 ? 'in ' + diffH + 'h' : Math.abs(diffH) + 'h ago';
      if (diffD === 1) return 'tomorrow';
      if (diffD === -1) return 'yesterday';
      if (diffD === 0) return 'today';
      return diffD > 0 ? 'in ' + diffD + ' days' : Math.abs(diffD) + ' days ago';
    }
  }"
>

  <!-- Header -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
    <div class="flex items-center gap-3 flex-wrap mb-4">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= sc.bg %> <%= sc.text %>">
        <%= sc.label %>
      </span>
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200">
        <%= event.category %>
      </span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 leading-tight mb-3"><%= event.title %></h1>
    <p class="text-slate-600 text-base leading-relaxed"><%= event.description %></p>
  </div>

  <!-- Info grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

    <!-- Location -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex gap-4">
      <div class="mt-0.5 shrink-0 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Location</p>
        <p class="text-slate-800 font-medium"><%= event.location %></p>
      </div>
    </div>

    <!-- Organizer -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex gap-4">
      <div class="mt-0.5 shrink-0 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Organizer</p>
        <p class="text-slate-800 font-medium"><%= event.organizerName %></p>
      </div>
    </div>

    <!-- Start datetime -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex gap-4">
      <div class="mt-0.5 shrink-0 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Starts</p>
        <p class="text-slate-800 font-medium"><%= fmtDate(event.startDatetime) %></p>
        <span
          class="inline-block mt-1.5 text-xs font-medium text-blue-600 bg-blue-50 rounded-full px-2.5 py-0.5"
          x-text="relativeTime('<%= event.startDatetime %>')"
          x-cloak
        ></span>
      </div>
    </div>

    <!-- End datetime -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 flex gap-4">
      <div class="mt-0.5 shrink-0 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Ends</p>
        <p class="text-slate-800 font-medium"><%= fmtDate(event.endDatetime) %></p>
        <span
          class="inline-block mt-1.5 text-xs font-medium text-slate-500 bg-slate-100 rounded-full px-2.5 py-0.5"
          x-text="relativeTime('<%= event.endDatetime %>')"
          x-cloak
        ></span>
      </div>
    </div>

    <!-- Attendance -->
    <div id="attendance-count" class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 md:col-span-2 flex gap-4">
      <div class="mt-0.5 shrink-0 text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <div class="flex-1">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Attendance</p>
        <% if (event.capacity !== null) { %>
          <p class="text-slate-800">
            <span class="text-lg font-bold"><%= attendeeCount %></span>
            <span class="text-slate-500 text-sm"> / <%= event.capacity %> spots</span>
          </p>
          <div class="mt-2 h-2 w-full rounded-full bg-slate-100 overflow-hidden">
            <div class="h-2 rounded-full transition-all <%= fillColor %>" style="width: <%= fillPct %>%"></div>
          </div>
          <p class="text-xs text-slate-500 mt-1"><%= fillPct %>% full</p>
        <% } else { %>
          <p class="text-slate-800">
            <span class="text-lg font-bold"><%= attendeeCount %></span>
            <span class="text-slate-500 text-sm"> attending · no capacity limit</span>
          </p>
        <% } %>
      </div>
    </div>

  </div>

  <!-- Actions -->
  <div id="lifecycle-controls" class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-base font-semibold text-slate-900 mb-4">Actions</h2>

    <% if (waitlistPosition !== null && waitlistPosition !== undefined) { %>
      <div class="rounded-lg border border-yellow-300 bg-yellow-50 p-4 text-sm text-yellow-800 mb-4">
        <p class="font-semibold">You are on the waitlist</p>
        <p>Your current position: <strong>#<%= waitlistPosition %></strong></p>
        <p class="text-xs mt-1 text-yellow-600">You will be automatically promoted if a spot opens up.</p>
      </div>
    <% } %>

    <div class="flex flex-wrap gap-3">

      <% if (event.canEdit) { %>
        <a
          href="/events/<%= event.id %>/edit"
          class="inline-block rounded-lg bg-slate-800 hover:bg-slate-900 text-white px-4 py-2 text-sm font-medium transition-colors no-underline"
        >
          Edit Event
        </a>
      <% } %>

      <% if (event.canPublish) { %>
        <form hx-post="/events/<%= event.id %>/publish" hx-target="#lifecycle-controls" hx-swap="outerHTML">
          <button
            type="submit"
            class="rounded-lg bg-green-600 hover:bg-green-700 text-white px-4 py-2 text-sm font-medium transition-colors"
          >
            Publish Event
          </button>
        </form>
      <% } %>

      <% if (event.canCancel && event.status === 'published') { %>
        <div x-data="{ open: false }">
          <button
            @click="open = true"
            class="rounded-lg bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium transition-colors"
          >
            Cancel Event
          </button>
          <div
            x-show="open"
            x-cloak
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/40"
            @click="open = false"
          >
            <div class="bg-white rounded-xl shadow-xl p-6 max-w-sm w-full mx-4" @click.stop>
              <h3 class="text-lg font-semibold text-slate-900 mb-2">Cancel this event?</h3>
              <p class="text-sm text-slate-600 mb-6">This will mark the event as cancelled. Attendees will no longer be able to RSVP.</p>
              <div class="flex gap-3 justify-end">
                <button
                  @click="open = false"
                  class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition-colors"
                >
                  Go back
                </button>
                <form hx-post="/events/<%= event.id %>/cancel" hx-target="#lifecycle-controls" hx-swap="outerHTML">
                  <button
                    type="submit"
                    class="rounded-lg bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium transition-colors"
                  >
                    Yes, cancel it
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% } %>

      <% if (event.canRsvp) { %>
        <%- include('../partials/rsvp-button', {
          eventId: event.id,
          rsvpStatus: currentUserRsvpStatus,
          rsvpError: null,
          attendeeCount: null
        }) %>
      <% } %>

    </div>
  </div>

</div>
