<%- contentFor('body') %>

<div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 rounded-3xl border border-slate-200 bg-white/80 p-6 shadow-xl shadow-slate-200/60 backdrop-blur sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Member Dashboard</p>
        <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">My RSVPs</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600 sm:text-base">
          Track the events you plan to attend, review archived RSVPs, and cancel an upcoming RSVP without leaving the page.
        </p>
      </div>

      <a
        href="/home"
        class="inline-flex items-center justify-center rounded-full border border-sky-200 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-100"
      >
        Browse more events
      </a>
    </div>
  </div>

  <div id="rsvp-list">
    <%- include('partials/rsvp-list', { rsvps }) %>
  </div>
</div>